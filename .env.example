# Supabase: Project Settings → Database → URI (Transaction or Direct).
# If Prisma says "empty host", the password likely has unescaped @ # : — URL-encode them (e.g. @ → %40).
DATABASE_URL=
# Local Redis (Docker): map 6379 and use redis://localhost:6379
REDIS_URL=redis://localhost:6379
SUPABASE_URL=
SUPABASE_ANON_KEY=
OPENROUTER_API_KEY=
RESEND_API_KEY=
DEMO_DATE=
# Optional overrides (defaults in src/lib/config.ts: Moonshot Kimi K2 on OpenRouter)
MODEL_DEV=
MODEL_DEMO=
MODEL_EVAL_JUDGE=
DRY_RUN=true
NODE_ENV=development
WEBHOOK_SECRET=
# Optional: cap Mastra pg pool (default 5). Lower if you still hit Supabase max connections.
MASTRA_PG_POOL_MAX=
# Self-correcting prompt pipeline guardrails (see src/lib/mutation-circuit.ts)
# MUTATION_MAX_CONSECUTIVE_REJECTIONS=3
# MUTATION_COOLDOWN_MINUTES=5
# MUTATION_CIRCUIT_PAUSE_HOURS=24
