# ── Database ──────────────────────────────────────────────────────────────────
# Supabase Postgres connection string (direct or pooler URI from Supabase → Settings → Database).
# If Prisma reports "empty host", URL-encode special characters in the password (@ # : → %40 %23 %3A).
# Required for Prisma and the app.
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# OpenRouter API key. Create at https://openrouter.ai/keys — required for agents and LLM scorers.
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Optional: override default OpenRouter model ids (defaults in src/lib/config.ts).
MODEL_DEV=moonshotai/kimi-k2
MODEL_DEMO=moonshotai/kimi-k2
MODEL_EVAL_JUDGE=moonshotai/kimi-k2

# ── Queue (BullMQ) ───────────────────────────────────────────────────────────
# Redis URL for BullMQ (workers, simulation jobs). Local: redis://localhost:6379 — Upstash works for cloud.
REDIS_URL=redis://localhost:6379

# ── App ─────────────────────────────────────────────────────────────────────
# Supabase project URL (REST / Realtime). Defaults in config if unset for local-only dev.
SUPABASE_URL=https://your-project.supabase.co

# Public anon key (browser client). Pair with NEXT_PUBLIC_* for SSR/client components.
SUPABASE_ANON_KEY=your_anon_key

# Used by client-side Supabase helpers — typically same URL and anon key as above.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Resend API key for outbound email. Required when not in DRY_RUN for real sends.
RESEND_API_KEY=re_your_key_here

# Fixed "current" datetime for demos and deterministic tests (ISO 8601). Strongly recommended for local dev.
DEMO_DATE=2025-03-20T12:00:00.000Z

# When true, emails and other side effects are suppressed; DB writes still occur per project rules.
DRY_RUN=true

# Node environment: development | production | test
NODE_ENV=development

# Shared secret for Supabase → app webhooks (document upload pipeline).
WEBHOOK_SECRET=your_webhook_secret

# Optional: Supabase service role for server-side Realtime broadcast (omit if unused).
SUPABASE_SERVICE_ROLE_KEY=

# Optional: secret for GET /api/cron/scheduled-scans (omit disables cron auth check path).
CRON_SECRET=

# Simulation time scaling (defaults to 1). Used where sim time is derived from config.
SIM_TIME_SCALE=1

# Optional: CI git SHA stored on EvalRun rows when running evals in pipelines.
GITHUB_SHA=

# Cap shared Mastra @mastra/pg pool size (default 5). Lower on Supabase if you hit connection limits.
MASTRA_PG_POOL_MAX=5

# Self-correcting prompt pipeline — max consecutive gate rejections before enqueue is blocked (default 3).
MUTATION_MAX_CONSECUTIVE_REJECTIONS=3

# Minimum minutes between mutation-analysis enqueues (default 5).
MUTATION_COOLDOWN_MINUTES=5

# Hours to pause new enqueues after circuit trips (default 24). Set 0 to block until manual reset.
MUTATION_CIRCUIT_PAUSE_HOURS=24

# ── CI / CD (optional) ───────────────────────────────────────────────────────
# Used by hosted CI to tag eval runs; leave empty for local runs.
