{
  "name": "cerebro",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "test": "vitest run",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "seed": "node --env-file=.env.local --import tsx prisma/seed.ts",
    "seed:prompts": "node --env-file=.env.local --import tsx prisma/seeds/seed-prompt-versions.ts",
    "reset-demo": "tsx scripts/reset-demo.ts",
    "eval": "node --env-file=.env.local --import tsx src/evals/run.ts --enforce-threshold",
    "eval:dev": "node --env-file=.env.local --import tsx src/evals/run.ts",
    "benchmark-report": "tsx scripts/benchmark-report.ts",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "simulation:smoke": "tsx scripts/smoke-simulation.ts",
    "simulation:real-eval": "tsx scripts/simulation-with-eval.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "node --env-file=.env.local --import tsx prisma/seeds/seed-prompt-versions.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:validate": "node --env-file=.env.local ./node_modules/prisma/build/index.js validate",
    "workers": "concurrently \"tsx src/workers/mutation-analysis.worker.ts\" \"tsx src/workers/shadow-runner.worker.ts\"",
    "workers:mutation": "tsx src/workers/mutation-analysis.worker.ts",
    "workers:shadow": "tsx src/workers/shadow-runner.worker.ts",
    "setup": "npm install && npx prisma generate && npx prisma migrate dev && npm run db:seed",
    "self-correcting:prep": "node --env-file=.env.local --import tsx scripts/self-correcting-pipeline.ts",
    "self-correcting:test": "node --env-file=.env.local --import tsx scripts/self-correcting-pipeline.ts --trigger-eval"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j86park/cerebro.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/j86park/cerebro/issues"
  },
  "homepage": "https://github.com/j86park/cerebro#readme",
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@mastra/core": "^1.13.2",
    "@mastra/memory": "^1.8.2",
    "@mastra/pg": "^1.8.0",
    "@openrouter/ai-sdk-provider": "^2.3.1",
    "@prisma/client": "^5.22.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tailwindcss/postcss": "^4.2.1",
    "bullmq": "^5.71.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.577.0",
    "next": "^15.5.12",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.2",
    "dotenv": "^17.3.1",
    "eslint": "^9.21.0",
    "eslint-config-next": "^15.5.12",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
